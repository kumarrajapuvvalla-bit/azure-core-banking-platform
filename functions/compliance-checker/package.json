{
  "name": "compliance-checker",
  "version": "1.0.0",
  "description": "Azure Function: FCA compliance tag checker for Azure resources",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "start": "func start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/arm-resources": "^5.2.0",
    "@azure/functions": "^3.5.1",
    "@azure/identity": "^4.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["*.ts", "!*.test.ts", "!*.d.ts"]
  }
}
